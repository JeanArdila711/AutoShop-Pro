# ─────────────────────────────────────────────────────────────
# Variables de entorno de AutoShop Pro
# Copiar a .env y rellenar los valores reales
# ─────────────────────────────────────────────────────────────

# Entorno: DEV (mocks) o PROD (servicios reales)
ENV_TYPE=DEV

# Django
DJANGO_SECRET_KEY=cambiar-en-produccion
DJANGO_DEBUG=True

# Redis (Message Broker para Celery)
REDIS_URL=redis://redis:6379/0

# SendGrid (API de terceros — Adapter Pattern)
# Obtener key en: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@autoshop.local

# Equipo aliado (URL del servicio que vamos a consumir)
ALIADO_API_URL=
